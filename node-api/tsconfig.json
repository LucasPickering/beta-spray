{
  "compilerOptions": {
    "baseUrl": "src",
    "target": "es6",
    "lib": ["esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "outDir": "build/"
  },
  "rules": {
    "no-unused-vars": "off"
  },
  "include": ["src"],
  "exclude": ["./build/**"]
}
