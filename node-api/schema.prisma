datasource db {
    url      = env("DATABASE_URL")
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
}

generator nexusPrisma {
    provider = "nexus-prisma"
}

model Boulder {
    id        Int      @id @default(autoincrement())
    name      String
    imageUrl  String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum AnnotationSource {
    USER
    AUTO
}

enum BodyPart {
    LEFT_HAND
    RIGHT_HAND
    LEFT_ROOT
    RIGHT_FOOT
}
