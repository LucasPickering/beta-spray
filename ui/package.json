{
  "name": "beta-spray-ui",
  "license": "MIT",
  "author": "Lucas Pickering <lucas@lucaspickering.me>",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.9.0",
    "@emotion/styled": "^11.8.1",
    "@mui/icons-material": "^5.8.3",
    "@mui/material": "^5.8.3",
    "@types/jest": "^28.1.1",
    "@types/react": "^18.0.12",
    "@types/react-dom": "^18.0.5",
    "@types/react-relay": "^13.0.2",
    "@types/relay-runtime": "^13.0.3",
    "@typescript-eslint/eslint-plugin": "^5.27.1",
    "@typescript-eslint/parser": "^5.27.1",
    "@use-gesture/react": "^10.2.15",
    "browser-image-compression": "^2.0.0",
    "eslint": "^8.17.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-react": "^1.1.7",
    "eslint-plugin-jest": "^26.5.3",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.30.0",
    "eslint-plugin-react-hooks": "^4.5.0",
    "graphql": "^16.5.0",
    "jest": "^28.1.1",
    "next": "^12.1.6",
    "nodemon": "^2.0.16",
    "prettier": "^2.6.2",
    "react": "^18.1.0",
    "react-dnd": "^16.0.1",
    "react-dnd-touch-backend": "^16.0.1",
    "react-dom": "^18.1.0",
    "react-helmet-async": "^1.3.0",
    "react-relay": "^14.0.0",
    "relay-compiler": "^14.0.0",
    "ts-jest": "^28.0.4",
    "typescript": "^4.7.3"
  },
  "scripts": {
    "start": "next dev",
    "start:prd": "next start",
    "prebuild": "npm run clean && npm run relay",
    "build": "next build",
    "check": "npm run type-check && npm run lint",
    "analyze": "WEBPACK_BUNDLE_ANALYZER_MODE=server npm run build",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint:fix": "npm run lint -- --fix",
    "clean": "rm -rf build/",
    "test": "jest",
    "pretype-check": "npm run relay",
    "type-check": "tsc",
    "relay": "mkdir -p src/__generated__ && relay-compiler",
    "relay:watch": "nodemon -x \"npm run relay\" -w src -e \"ts tsx\" -i \"**/__generated__/*\""
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
